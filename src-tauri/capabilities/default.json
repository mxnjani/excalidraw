{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "opener:default",
    "dialog:default",
    "fs:default",
    { "identifier": "fs:allow-read-file", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-write-file", "allow": [{ "path": "**" }] }
  ]
}
